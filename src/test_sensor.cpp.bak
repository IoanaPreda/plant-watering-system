#include <Arduino.h>

#define MOISTURE_PIN 32

const int DRY = 2600;
const int WET = 1100;

int readMoistureAvg(int samples = 20) {
  long sum = 0;
  for (int i = 0; i < samples; i++) {
    sum += analogRead(MOISTURE_PIN);
    delay(5);
  }
  return sum / samples;
}

int moisturePercent(int raw) {
  raw = constrain(raw, WET, DRY);
  return map(raw, DRY, WET, 0, 100);
}

void setup() {
  Serial.begin(115200);
  delay(1000);

  analogSetAttenuation(ADC_11db); // full 0–3.3V
  Serial.println("Moisture sensor calibrated");
}

void loop() {
  int raw = readMoistureAvg(30);
  int pct = moisturePercent(raw);

  Serial.print("Raw: ");
  Serial.print(raw);
  Serial.print("  Moisture: ");
  Serial.print(pct);
  Serial.println("%");

  delay(2000);
}
